# Database
DATABASE_URL=sqlite+aiosqlite:///./grading.db

# JWT Secret Key (REQUIRED — generate with: openssl rand -hex 32)
SECRET_KEY=

# Fernet Encryption Key for API keys (REQUIRED — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# File storage path
STORAGE_PATH=./storage

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
